# Resend HTTP API credentials (used instead of SMTP — works on Railway)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=onboarding@resend.dev
# Note: "onboarding@resend.dev" works out-of-the-box but only sends to the Resend
# account owner's email. To send to other recipients, verify a domain at
# resend.com/domains and use a RESEND_FROM on that domain.
